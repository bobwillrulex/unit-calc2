<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0C0F16"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/formulaInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:hint="Use keypad to build expression"
            android:importantForAutofill="no"
            android:inputType="none"
            android:longClickable="false"
            android:padding="8dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#6D7485"
            android:textIsSelectable="false"
            android:textSize="26sp" />

        <ImageButton
            android:id="@+id/historyButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="History"
            android:src="@android:drawable/ic_menu_recent_history"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <TextView
        android:id="@+id/resultText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="end"
        android:minHeight="44dp"
        android:textColor="#8FE6B1"
        android:textSize="28sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnConvert"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Convert" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Recent units"
        android:textColor="#9EA5B6" />

    <HorizontalScrollView
        android:id="@+id/recentUnitsScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/recentUnitContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:tabIndicatorColor="#8FE6B1"
        app:tabIndicatorFullWidth="false"
        app:tabMode="fixed"
        app:tabRippleColor="#304458"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabTextColor="#8E93A6" />

    <LinearLayout
        android:id="@+id/pageCalculator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="5"
            android:rowCount="6"
            android:useDefaultMargins="false">

            <Button android:id="@+id/btnAc" style="@style/CalcButtonSecondary" android:text="AC" />
            <Button android:id="@+id/btnLParen" style="@style/CalcButtonSecondary" android:text="(" />
            <Button android:id="@+id/btnRParen" style="@style/CalcButtonSecondary" android:text=")" />
            <Button android:id="@+id/btnFrac" style="@style/CalcButtonSecondary" android:text="a/b" />
            <Button android:id="@+id/btnDel" style="@style/CalcButtonSecondary" android:text="DEL" />

            <Button android:id="@+id/btnPow" style="@style/CalcButtonSecondary" android:text="^" />
            <Button android:id="@+id/btnSqrt" style="@style/CalcButtonSecondary" android:text="√" />
            <Button android:id="@+id/btnAns" style="@style/CalcButtonSecondary" android:text="ANS" />
            <Button android:id="@+id/btnDiv" style="@style/CalcButtonOperator" android:text="÷" />
            <Button android:id="@+id/btnMul" style="@style/CalcButtonOperator" android:text="×" />

            <Button android:id="@+id/btn7" style="@style/CalcButton" android:text="7" />
            <Button android:id="@+id/btn8" style="@style/CalcButton" android:text="8" />
            <Button android:id="@+id/btn9" style="@style/CalcButton" android:text="9" />
            <Button android:id="@+id/btnMinus" style="@style/CalcButtonOperator" android:text="−" />
            <Button android:id="@+id/btnPlus" style="@style/CalcButtonOperator" android:text="+" />

            <Button android:id="@+id/btn4" style="@style/CalcButton" android:text="4" />
            <Button android:id="@+id/btn5" style="@style/CalcButton" android:text="5" />
            <Button android:id="@+id/btn6" style="@style/CalcButton" android:text="6" />
            <Button android:id="@+id/btn1" style="@style/CalcButton" android:text="1" />
            <Button android:id="@+id/btn2" style="@style/CalcButton" android:text="2" />

            <Button android:id="@+id/btn3" style="@style/CalcButton" android:text="3" />
            <Button android:id="@+id/btn0" style="@style/CalcButton" android:text="0" />
            <Button android:id="@+id/btnDot" style="@style/CalcButton" android:text="." />
            <Button android:id="@+id/btnEq" style="@style/CalcButtonAccent" android:text="=" />
        </GridLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/pageLength"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tap to insert length units" android:textColor="#A8ABB5" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/lenBtn0" style="@style/CalcButton" />
            <Button android:id="@+id/lenBtn1" style="@style/CalcButton" />
            <Button android:id="@+id/lenBtn2" style="@style/CalcButton" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/lenBtn3" style="@style/CalcButton" />
            <Button android:id="@+id/lenBtn4" style="@style/CalcButton" />
            <Button android:id="@+id/lenBtn5" style="@style/CalcButton" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/pageVolume"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tap to insert volume units" android:textColor="#A8ABB5" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/volBtn0" style="@style/CalcButton" />
            <Button android:id="@+id/volBtn1" style="@style/CalcButton" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
